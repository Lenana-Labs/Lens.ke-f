# Django backend base URL — no trailing slash
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# simplejwt default endpoint paths
NEXT_PUBLIC_AUTH_TOKEN_OBTAIN=/api/v1/auth/login
NEXT_PUBLIC_AUTH_TOKEN_REFRESH=/api/v1/auth/refresh
NEXT_PUBLIC_AUTH_TOKEN_VERIFY=/api/v1/auth/verify

# Supabase — leave blank until/unless direct Storage or Realtime is needed
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

NEXT_PUBLIC_APP_ENV=development
